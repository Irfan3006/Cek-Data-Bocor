# URL API XposedOrNot (Bawaan: https://api.xposedornot.com/v1)
XPOSEDORNOT_API_URL=https://api.xposedornot.com/v1

# Waktu simpan cache dalam detik (Bawaan: 600 detik - 10 menit)
CACHE_TTL_SECONDS=600

# Batas maksimal request rate limiter per IP (Bawaan: 10)
RATE_LIMIT_REQUESTS=10

# Jendela waktu rate limiter dalam detik (Bawaan: 60 detik - 1 menit)
RATE_LIMIT_WINDOW_SECONDS=60

# Secret key untuk HMAC signing PoW challenge (WAJIB diubah di production)
POW_SECRET_KEY=your-random-secret-key-here-wajib-ganti-untuk-anti-bot

# Difficulty PoW: jumlah leading hex zeros (Bawaan: 4, ~65K iterations)
POW_DIFFICULTY=4

# TTL challenge PoW dalam detik (Bawaan: 300 detik - 5 menit)
POW_TTL_SECONDS=300
