---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  schemaJson?: object;
}

const { 
  title, 
  description, 
  canonicalPath = Astro.url.pathname,
  schemaJson 
} = Astro.props;

const siteName = "Data Bocor";
const baseUrl = "https://databocor.web.id"; // Fallback URL
const canonicalURL = new URL(canonicalPath, Astro.site ?? baseUrl).toString();

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "alternateName": ["Cek Data Bocor", "databocor.web.id"],
  "url": baseUrl,
  "description": "Layanan gratis untuk mendeteksi kebocoran email di Indonesia menggunakan database publik.",
  "inLanguage": "id-ID"
};

const finalSchema = schemaJson || defaultSchema;

const displayTitle = title.includes(siteName) || title.includes("Cek Data") 
  ? title 
  : `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="JkEZsggVN_wbA8UtybYd5O9f6OGE6EquUfTEfDU1rJY" />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9LWGWRMY93"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9LWGWRMY93');
    </script>
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{displayTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="cek data bocor, data bocor, cek data, cek email bocor, cek email, cek password bocor, cek akun, cek hacker, cybersecurity indonesia, periksa akun retas" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Cek Data Bocor" />
    <meta name="theme-color" content="#121318" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Geo Tags for Indonesian Audience -->
    <meta name="geo.region" content="ID" />
    <meta name="geo.position" content="-0.789275;113.921327" />
    <meta name="ICBM" content="-0.789275, 113.921327" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={`${baseUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="id_ID" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={displayTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${baseUrl}/og-image.png`} />

    <!-- Google Fonts - Inter (Premium typography) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
  </head>
  <body class="flex flex-col min-h-screen">
    <slot />
  </body>
</html>
