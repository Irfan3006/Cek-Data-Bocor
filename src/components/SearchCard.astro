---
interface Props {
  initialValue?: string;
}

const { initialValue = "" } = Astro.props;
---

<div class="bg-neutral-bgAlt border border-neutral-border p-6 rounded-lg max-w-xl mx-auto w-full">
  <form action="/check" method="GET" id="check-form" class="space-y-4" novalidate>
    <div class="flex flex-col space-y-2">
      <label for="email" class="text-sm font-semibold text-neutral-text">
        Alamat Email Anda
      </label>
      <div class="relative">
        <input
          type="email"
          name="email"
          id="email"
          value={initialValue}
          placeholder="Masukkan alamat email (contoh: budi@gmail.com)"
          class="w-full px-4 py-3 border border-neutral-border rounded-md text-neutral-text bg-neutral-bgAlt placeholder-neutral-textMuted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
          required
          aria-required="true"
          aria-describedby="email-error"
          autocomplete="email"
        />
      </div>
      <p id="email-error" class="text-xs text-danger hidden" role="alert"></p>
    </div>

    <button
      type="submit"
      class="w-full py-3 px-4 bg-primary hover:bg-primary-dark text-white font-semibold rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 ring-offset-neutral-bg flex items-center justify-center space-x-2"
      aria-label="Tombol Cek Data Bocor"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.637 10.637Z" />
      </svg>
      <span>Cek Sekarang</span>
    </button>
  </form>
</div>

<script>
  const form = document.getElementById("check-form") as HTMLFormElement | null;
  const input = document.getElementById("email") as HTMLInputElement | null;
  const errorMsg = document.getElementById("email-error") as HTMLParagraphElement | null;

  const emailRegex = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;

  form?.addEventListener("submit", (event) => {
    if (!input || !errorMsg) return;

    const rawVal = input.value.trim();
    
    if (!rawVal) {
      event.preventDefault();
      errorMsg.textContent = "Alamat email wajib diisi.";
      errorMsg.classList.remove("hidden");
      input.classList.add("border-danger");
      return;
    }

    if (!emailRegex.test(rawVal)) {
      event.preventDefault();
      errorMsg.textContent = "Format email tidak valid. Masukkan email yang benar.";
      errorMsg.classList.remove("hidden");
      input.classList.add("border-danger");
      return;
    }

    input.value = rawVal.toLowerCase();
    errorMsg.classList.add("hidden");
    input.classList.remove("border-danger");
  });

  input?.addEventListener("input", () => {
    if (input && errorMsg) {
      errorMsg.classList.add("hidden");
      input.classList.remove("border-danger");
    }
  });
</script>
