---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path ? "text-primary font-semibold" : "text-neutral-textMuted hover:text-primary";
---

<header class="bg-neutral-bg/80 backdrop-blur-xl border-b border-neutral-border sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-4" aria-label="Navigasi Utama">
    <a href="/" class="flex items-center space-x-2 text-primary focus-visible:ring-2 focus-visible:ring-primary" aria-label="Kembali ke Beranda Cek Data Bocor">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
      </svg>
      <span class="font-bold text-lg tracking-tight select-none">Cek Data Bocor</span>
    </a>
    
    <div class="flex items-center space-x-5 sm:space-x-6 text-sm" role="menubar">
      <a href="/about" class={`transition-colors py-1 ${isActive('/about')}`} role="menuitem">
        Tentang
      </a>
      <a href="/faq" class={`transition-colors py-1 ${isActive('/faq')}`} role="menuitem">
        FAQ
      </a>
      <a href="/privacy" class={`transition-colors py-1 ${isActive('/privacy')}`} role="menuitem">
        Privasi
      </a>
      <a href="/contact" class={`transition-colors py-1 ${isActive('/contact')}`} role="menuitem">
        Kontak
      </a>
    </div>
  </nav>
</header>
