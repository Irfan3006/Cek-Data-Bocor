---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="space-y-4 max-w-3xl mx-auto w-full" role="list">
  {items.map((item: FAQItem, index: number) => (
    <details 
      class="group bg-neutral-bg border border-neutral-border rounded-lg transition-colors duration-150 overflow-hidden [&_summary::-webkit-details-marker]:hidden"
      role="listitem"
    >
      <summary 
        class="flex justify-between items-center p-5 font-semibold text-neutral-text cursor-pointer hover:bg-neutral-bgAlt select-none focus:outline-none list-none"
        aria-controls={`faq-answer-${index}`}
      >
        <span class="pr-4 leading-snug">{item.question}</span>
        <!-- Icon panah minimalis -->
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          fill="none" 
          viewBox="0 0 24 24" 
          stroke-width="2" 
          stroke="currentColor" 
          class="w-5 h-5 text-neutral-textMuted group-open:rotate-180 transition-transform duration-200 flex-shrink-0"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </summary>
      
      <div 
        id={`faq-answer-${index}`} 
        class="border-t border-neutral-border p-5 text-sm text-neutral-textMuted leading-relaxed bg-neutral-bg"
      >
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>
