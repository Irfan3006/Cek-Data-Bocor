---

<div class="space-y-6 max-w-2xl mx-auto w-full animate-pulse" aria-hidden="true" role="status" aria-label="Memeriksa basis data kebocoran...">
  <!-- Risk Score Skeleton -->
  <div class="bg-neutral-bg border border-neutral-border p-6 rounded-lg flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="space-y-2 flex-1">
      <div class="h-4 bg-neutral-border rounded w-1/4"></div>
      <div class="h-8 bg-neutral-border rounded w-1/2"></div>
    </div>
    <div class="w-24 h-24 rounded-full bg-neutral-border"></div>
  </div>

  <!-- Recommendations Skeleton -->
  <div class="space-y-4">
    <div class="h-5 bg-neutral-border rounded w-1/3"></div>
    <div class="bg-neutral-bg border border-neutral-border p-6 rounded-lg space-y-3">
      <div class="h-6 bg-neutral-border rounded w-1/4"></div>
      <div class="h-4 bg-neutral-border rounded w-3/4"></div>
      <div class="h-4 bg-neutral-border rounded w-5/6"></div>
    </div>
  </div>

  <!-- Breaches List Skeleton -->
  <div class="space-y-4">
    <div class="h-5 bg-neutral-border rounded w-1/3"></div>
    <div class="bg-neutral-bg border border-neutral-border p-6 rounded-lg space-y-4">
      <div class="flex items-center space-x-4">
        <div class="w-12 h-12 bg-neutral-border rounded"></div>
        <div class="space-y-2 flex-1">
          <div class="h-5 bg-neutral-border rounded w-1/5"></div>
          <div class="h-4 bg-neutral-border rounded w-1/3"></div>
        </div>
      </div>
      <div class="h-px bg-neutral-border"></div>
      <div class="h-16 bg-neutral-border rounded w-full"></div>
    </div>
  </div>
</div>
